# ============================================================================
# Google Cloud Run Environment Configuration Example
# ============================================================================
# This file contains example environment variables for Cloud Run deployment.
# 
# IMPORTANT: 
# - Do NOT commit actual secrets to version control
# - Use Google Secret Manager for sensitive values (GEMINI_API_KEY, DATABASE_URL)
# - Non-sensitive vars can be set directly in deploy.sh or Cloud Run console
# ============================================================================

# Application Configuration
APP_NAME="Thesis Agent Backend"
ENVIRONMENT=prod                    # Options: local, dev, staging, prod
LOG_LEVEL=INFO                      # Options: DEBUG, INFO, WARNING, ERROR

# Server Configuration (Cloud Run automatically sets PORT to 8080)
PORT=8080
CORS_ORIGINS=https://your-frontend-domain.com,https://api.your-domain.com

# Database Configuration - USE SECRET MANAGER FOR THIS
# Example Neon connection string format:
# DATABASE_URL=postgresql+psycopg2://user:password@host.region.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql+psycopg2://YOUR_USER:YOUR_PASSWORD@YOUR_HOST.neon.tech/YOUR_DB?sslmode=require

# Gemini API Configuration - USE SECRET MANAGER FOR API KEY
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GEMINI_EMBEDDING_DIM=768

# MCP Configuration (Optional)
MCP_SYSTEM_PROMPT="You are a helpful AI assistant for ad campaign analysis."

# ============================================================================
# Setting up secrets in Google Secret Manager:
# ============================================================================
# 
# 1. Create GEMINI_API_KEY secret:
#    echo -n "your_actual_gemini_api_key" | gcloud secrets create GEMINI_API_KEY --data-file=-
#
# 2. Create DATABASE_URL secret:
#    echo -n "postgresql+psycopg2://user:pass@host/db" | gcloud secrets create DATABASE_URL --data-file=-
#
# 3. Grant Cloud Run service account access:
#    gcloud projects add-iam-policy-binding PROJECT_ID \
#      --member="serviceAccount:PROJECT_NUMBER-compute@developer.gserviceaccount.com" \
#      --role="roles/secretmanager.secretAccessor"
#
# 4. The deploy.sh script automatically mounts these secrets as environment variables
# ============================================================================
